{
  "name": "@klaudworks/shopify-mcp",
  "version": "1.1.0",
  "description": "MCP Server for Shopify API, enabling interaction with store data through GraphQL API",
  "main": "dist/index.js",
  "bin": "dist/index.js",
  "type": "module",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "rimraf dist && tsc",
    "start": "node dist/index.js",
    "dev": "node --loader ts-node/esm src/index.ts",
    "test": "echo '(no tests yet — placeholder so CI stays green; swap in node --test when tests are added)' && exit 0",
    "prepublishOnly": "npm run build",
    "clean": "rimraf dist"
  },
  "keywords": [
    "shopify",
    "mcp",
    "model-context-protocol",
    "graphql",
    "ai",
    "llm",
    "claude"
  ],
  "author": {
    "name": "Your Name",
    "email": "your.email@example.com",
    "url": "https://your-website.com"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^16.0.3",
    "graphql": "^16.6.0",
    "graphql-request": "^7.4.0",
    "minimist": "^1.2.8",
    "zod": "^3.21.4"
  },
  "devDependencies": {
    "@types/minimist": "^1.2.2",
    "@types/node": "^22.10.0",
    "rimraf": "^5.0.10",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.4"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/klaudworks/shopify-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/klaudworks/shopify-mcp/issues"
  },
  "homepage": "https://github.com/klaudworks/shopify-mcp#readme",
  "engines": {
    "node": ">=18.0.0"
  }
}
